# App owner
APP_OWNER_ID=personal-owner-local
IELTS_GOAL=IELTS Listening Band 7+

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/english_for_only_me

# YouTube metadata import
# Optional. When empty, YouTube imports are saved as URL-only drafts.
YOUTUBE_API_KEY=

# AI debrief and translation provider
# Optional. When empty, AI-powered features return an unavailable state.
OPENAI_API_KEY=
OPENAI_DEBRIEF_MODEL=gpt-5.4-nano
OPENAI_TRANSLATION_MODEL=gpt-5.4-nano
