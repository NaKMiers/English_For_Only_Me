# =============================================================================
# App
# =============================================================================
IELTS_GOAL=IELTS Listening Band 7+
# Canonical site origin for SEO (sitemap, Open Graph). No trailing slash.
SITE_URL=http://localhost:3000


# =============================================================================
# Database
# =============================================================================
# Active database connection.
MONGODB_URI=mongodb://127.0.0.1:27017/english_for_only_me
# Alternative - Local
# MONGODB_URI=mongodb://127.0.0.1:27017/english_for_only_me


# =============================================================================
# External APIs - YouTube
# =============================================================================
# Optional. When empty, YouTube imports are saved as URL-only drafts.
YOUTUBE_API_KEY=


# =============================================================================
# AI - Debrief & Translation
# =============================================================================
# Optional. When empty, AI-powered features return an unavailable state.
OPENAI_API_KEY=
OPENAI_DEBRIEF_MODEL=gpt-5.4-nano
OPENAI_TRANSLATION_MODEL=gpt-5.4-nano


# =============================================================================
# Storage - Cloudinary
# =============================================================================
# Used by admin topic thumbnail uploads. Keep this server-only.
CLOUDINARY_URL=


# =============================================================================
# Auth & Secrets (server-only)
# =============================================================================
# Google authentication (Auth.js v5)
# Authorized redirect URI: <origin>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Generate with: openssl rand -base64 33   (or: npx auth secret)
AUTH_SECRET=
# Comma-separated Google emails granted the admin role.
ADMIN_EMAILS=
